model_info <- tibble(
  Model = c("M0","M0w","M1","M2","M3","M4","M5"),
  Variance_structure = c(
    "LMM - original",
    "LMM - weights = 1/sqrt(n_eff)",
    "varFixed(1/sqrt(n_eff))",
    "varPower(n_eff)",
    "varPower(n_eff) + varIdent(Tipo)",
    "varPower(n_eff) + varIdent(ff_area)",
    "varPower(n_eff) + varIdent(Tipo:ff_area)"
  )
)

model_comp <- bind_rows(aic_cba, aic_eba, aic_sba) %>%
  left_join(bind_rows(bic_cba, bic_eba, bic_sba), by = c("Region","Model")) %>%
  left_join(model_info, by = "Model") %>%
  dplyr::select(Region, Model, Variance_structure, df, AIC, BIC) %>%
  arrange(Region, Model) %>%
  mutate(
    AIC = round(AIC, 3),
    BIC = round(BIC, 3)
  )

write.xlsx(
  list(
    "Model_comparison_long" = model_comp
  ),
  file = "data_group/model_comparison_prec.xlsx",
  overwrite = TRUE
)

