### Statistics

#### Heterocedasticidade




```{r}

plot_resid_hetero <- function(model, dat, region_name,
                              show_x_lab = TRUE,
                              show_y_lab = TRUE) {

  rn <- if (inherits(model, c("gls", "lme"))) {
    residuals(model, type = "normalized")
  } else if (inherits(model, "merMod")) {
    residuals(model, type = "pearson")
  } else {
    residuals(model)
  }

  ggplot(data.frame(n_obs = dat$n_obs, rnorm = rn),
         aes(n_obs, rnorm)) +
    geom_point(alpha = .35) +
    geom_smooth(method = "loess", se = FALSE) +
    geom_hline(yintercept = 0, lty = 2, col = "grey40") +
    scale_x_log10() +
    ggthemes::theme_few() +
    theme(
      text = element_text(size = 12, face = "bold", family = "serif"),
      plot.title = element_text(hjust = 0.5)
    ) +
    labs(
      title = region_name,
      x = if (show_x_lab) "" else NULL,
      y = if (show_y_lab) "Residuals" else NULL
    )
}

p_het_cba <- plot_resid_hetero(model_CBA_evapo_main, model_cba_evapo, "",
                               show_x_lab = FALSE, show_y_lab = TRUE)

p_het_eba <- plot_resid_hetero(model_EBA_evapo_main, model_eba_evapo, "",
                               show_x_lab = TRUE, show_y_lab = FALSE)

p_het_sba <- plot_resid_hetero(model_SBA_evapo_main, model_sba_evapo, "",
                               show_x_lab = FALSE, show_y_lab = FALSE)


painel_het_evapo <- ggpubr::ggarrange(p_het_cba, p_het_eba, p_het_sba,
                                     ncol = 3, nrow = 1, align = "hv")

painel_het_evapo

ggsave("fig/supplemental_material/hetero_residuals_lme_evapo.png", width=8, height=6, dpi=400, bg="white")

