emm_CBA_temp_main <- emmeans(model_CBA_temp_main, ~ Tipo | ff_area)
emm_EBA_temp_main <- emmeans(model_EBA_temp_main, ~ Tipo | ff_area)
emm_SBA_temp_main <- emmeans(model_SBA_temp_main, ~ Tipo | ff_area)

emm_CBA_temp_main
emm_EBA_temp_main
emm_SBA_temp_main

pairs_CBA_temp_main <- pairs(emm_CBA_temp_main, by = "ff_area", adjust = "BH")
pairs_EBA_temp_main <- pairs(emm_EBA_temp_main, by = "ff_area", adjust = "BH")
pairs_SBA_temp_main <- pairs(emm_SBA_temp_main, by = "ff_area", adjust = "BH")

pairs_CBA_temp_main
