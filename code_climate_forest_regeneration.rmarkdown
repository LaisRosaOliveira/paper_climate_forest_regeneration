#### M5




```{r}

model_CBA_prec_main5 <- gls(
  Prec ~ ff_area * Tipo + factor(Ano),
  weights = varComb(
    varPower(form = ~ n_eff),
    varIdent(form = ~ 1 | Tipo*ff_area)),
  data = model_cba_prec,
  method = "REML",
  control = glsControl(
    maxIter = 200,
    msMaxIter = 200,
    tolerance = 1e-6,
    opt = "optim"
  )
)

model_EBA_prec_main5 <- gls(
  Prec ~ ff_area * Tipo + factor(Ano),
  weights = varComb(
    varPower(form = ~ n_eff),
    varIdent(form = ~ 1 | Tipo*ff_area)),
  data = model_eba_prec,
  method = "REML",
  control = glsControl(
    maxIter = 200,
    msMaxIter = 200,
    tolerance = 1e-6,
    opt = "optim"
  )
)

model_SBA_prec_main5 <- gls(
  Prec ~ ff_area * Tipo + factor(Ano),
  weights = varComb(
    varPower(form = ~ n_eff),
    varIdent(form = ~ 1 | Tipo*ff_area)),
  data = model_sba_prec,
  method = "REML",
  control = glsControl(
    maxIter = 200,
    msMaxIter = 200,
    tolerance = 1e-6,
    opt = "optim"
  )
)

