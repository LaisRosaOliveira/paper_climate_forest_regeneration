][
  , cell_id := paste(Lon, Lat, sep = "_")
][
  , ff_area := fifelse(frac_area >= 0.01 & frac_area <= 0.10, "1-10",
                fifelse(frac_area > 0.10 & frac_area <= 0.20, "10-20",
                fifelse(frac_area > 0.20 & frac_area <= 0.30, "20-30",
                fifelse(frac_area > 0.30 & frac_area <= 0.40, "30-40",
                fifelse(frac_area > 0.40 & frac_area <= 0.50, "40-50",
                fifelse(frac_area > 0.50 & frac_area <= 0.60, "50-60",
                fifelse(frac_area > 0.60 & frac_area <= 0.70, "60-70",
                fifelse(frac_area > 0.70 & frac_area <= 0.80, "70-80",
                fifelse(frac_area > 0.80 & frac_area <= 0.90, "80-90",
                fifelse(frac_area > 0.90 & frac_area <= 1.00, "90-100", NA_character_))))))))))
][
  , idade_cat := fifelse(Idade_SF >= 0 & Idade_SF <= 10, "<= 10",
                  fifelse(Idade_SF > 10 & Idade_SF <= 20, "10-20",
                  fifelse(Idade_SF > 20, "> 20", NA_character_)))
][
  , Tipo_stage := fifelse(Tipo == "PF", "PF",
                   fifelse(Tipo == "SF" & idade_cat == "<= 10", "SF_early",
                   fifelse(Tipo == "SF" & idade_cat == "10-20", "SF_intermediate",
                   fifelse(Tipo == "SF" & idade_cat == "> 20", "SF_advanced", NA_character_))))
][
  !is.na(ff_area) & !is.na(Tipo_stage),
  .(cell_id, Region, Ano, Prec, ff_area, Tipo = Tipo_stage)
]

