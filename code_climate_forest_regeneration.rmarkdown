### Funções




```{r}

aggregate_temp <- function(dt_in) {
  agg_temp <- dt_in[
    ,
    .(
      Temp = mean(Temp, na.rm = TRUE),
      n_eff = .N
    ),
    by = .(Ano, Region, ff_area, Tipo)
  ]
  
  agg_temp[, Ano_num := as.integer(Ano)]
  agg_temp[, grupo_var := interaction(Tipo, ff_area, drop = TRUE)]
  agg_temp[, estrato_id := interaction(Tipo, ff_area, drop = TRUE)]
  
  as.data.frame(agg_temp)
}


fit_model_temp <- function(dat_agg_region_temp, model_type = c("lmm", "gls")) {
  model_type <- match.arg(model_type)
  
  if (model_type == "lmm") {
    fit_temp <- lmer(
      Temp ~ ff_area * Tipo + (1 | Ano),
      data = dat_agg_region_temp
    )
  } else {
    fit_temp <- gls(
      Temp ~ ff_area * Tipo + factor(Ano),
      weights = varComb(
        varPower(form = ~ n_eff),
        varIdent(form = ~ 1 | grupo_var)
      ),
      data = dat_agg_region_temp,
      method = "REML",
      na.action = na.omit
    )
  }
  
  attr(fit_temp, "boot_data_temp") <- dat_agg_region_temp
  fit_temp
}


extract_pf_sf_contrasts_temp <- function(model_obj_temp, region_name,
                                         rep_id = NA_integer_,
                                         source_label = NA_character_,
                                         model_type = NA_character_,
                                         method = NA_character_,
                                         frac_cells = NA_real_) {
  
  boot_data_temp <- attr(model_obj_temp, "boot_data_temp")
  
  emm_temp <- emmeans(
    model_obj_temp,
    ~ Tipo | ff_area,
    data = boot_data_temp
  )
  
  contr_temp <- summary(
    pairs(emm_temp, by = "ff_area", adjust = "none"),
    infer = c(TRUE, TRUE)
  ) %>%
    as.data.frame()
  
  contr_temp <- contr_temp[
    contr_temp$contrast %in% c("PF - SF_early", "PF - SF_intermediate", "PF - SF_advanced"),
  ]
  
  if (nrow(contr_temp) == 0) return(NULL)
  
  if (!"lower.CL" %in% names(contr_temp)) contr_temp$lower.CL <- NA_real_
  if (!"upper.CL" %in% names(contr_temp)) contr_temp$upper.CL <- NA_real_
  
  contr_temp$region <- region_name
  contr_temp$rep <- rep_id
  contr_temp$source <- source_label
  contr_temp$model_type <- model_type
  contr_temp$method <- method
  contr_temp$frac_cells <- frac_cells
  
  contr_temp
}


fit_full_by_region_temp <- function(dt_region_temp, region_name, model_type) {
  dat_agg_region_temp <- aggregate_temp(dt_region_temp)
  fit_temp <- fit_model_temp(dat_agg_region_temp, model_type = model_type)
  
  extract_pf_sf_contrasts_temp(
    fit_temp,
    region_name = region_name,
    rep_id = NA_integer_,
    source_label = paste0("model_", model_type),
    model_type = model_type,
    method = "full",
    frac_cells = 1
  )
}


fit_one_resample_region_temp <- function(dt_region_temp, region_name, rep_id,
                                         model_type = c("lmm","gls"),
                                         method = c("bootstrap","subsample"),
                                         frac_cells = 1) {
  
  model_type <- match.arg(model_type)
  method <- match.arg(method)
  
  ids_temp <- unique(dt_region_temp$cell_id)
  n_ids_temp <- length(ids_temp)
  n_use_temp <- max(1, floor(n_ids_temp * frac_cells))
  
  if (method == "bootstrap") {
    sampled_ids_temp <- sample(ids_temp, size = n_use_temp, replace = TRUE)
    sampled_dt_temp <- data.table(cell_id = sampled_ids_temp)[, .N, by = cell_id]
    setnames(sampled_dt_temp, "N", "n_rep")
    
    res_dt_temp <- merge(
      dt_region_temp,
      sampled_dt_temp,
      by = "cell_id",
      all = FALSE,
      allow.cartesian = TRUE
    )
    
    res_dt_temp <- res_dt_temp[rep(seq_len(.N), n_rep)]
    res_dt_temp[, n_rep := NULL]
    
  } else {
    sampled_ids_temp <- sample(ids_temp, size = n_use_temp, replace = FALSE)
    res_dt_temp <- dt_region_temp[cell_id %in% sampled_ids_temp]
  }
  
  dat_agg_region_temp <- aggregate_temp(res_dt_temp)
  
  fit_temp <- tryCatch(
    fit_model_temp(dat_agg_region_temp, model_type = model_type),
    error = function(e) NULL
  )
  
  if (is.null(fit_temp)) return(NULL)
  
  extract_pf_sf_contrasts_temp(
    fit_temp,
    region_name = region_name,
    rep_id = rep_id,
    source_label = paste0(method, "_", model_type, "_", frac_cells),
    model_type = model_type,
    method = method,
    frac_cells = frac_cells
  )
}


run_resample_region_temp <- function(dt_region_temp, region_name,
                                     model_type = c("lmm","gls"),
                                     method = c("bootstrap","subsample"),
                                     frac_cells = 1,
                                     B = 500,
                                     seed = 123) {
  
  model_type <- match.arg(model_type)
  method <- match.arg(method)
  
  set.seed(seed)
  res_list_temp <- vector("list", B)
  
  for (b in seq_len(B)) {
    cat(method, "|", model_type, "|", region_name, "| frac =", frac_cells, "|", b, "of", B, "\n")
    
    res_list_temp[[b]] <- fit_one_resample_region_temp(
      dt_region_temp = dt_region_temp,
      region_name = region_name,
      rep_id = b,
      model_type = model_type,
      method = method,
      frac_cells = frac_cells
    )
  }
  
  rbindlist(res_list_temp, fill = TRUE)
}


summarise_resamples_temp <- function(dt_res_temp) {
  dt_res_temp[
    ,
    .(
      n_rep = .N,
      mean_est = mean(estimate, na.rm = TRUE),
      sd_est = sd(estimate, na.rm = TRUE),
      q025 = quantile(estimate, 0.025, na.rm = TRUE),
      q975 = quantile(estimate, 0.975, na.rm = TRUE),
      prop_pos = mean(estimate > 0, na.rm = TRUE)
    ),
    by = .(region, ff_area, contrast, source, model_type, method, frac_cells)
  ]
}

```




### Execução




```{r,eval = FALSE, echo = TRUE}

model_lmm_all_temp <- rbindlist(list(
  fit_full_by_region_temp(pix_cba, "CBA", "lmm"),
  fit_full_by_region_temp(pix_eba, "EBA", "lmm"),
  fit_full_by_region_temp(pix_sba, "SBA", "lmm")
), fill = TRUE)

boot_lmm_all_temp <- rbindlist(list(
  run_resample_region_temp(pix_cba, "CBA", "lmm", "bootstrap", frac_cells = 1, B = 500, seed = 123),
  run_resample_region_temp(pix_eba, "EBA", "lmm", "bootstrap", frac_cells = 1, B = 500, seed = 124),
  run_resample_region_temp(pix_sba, "SBA", "lmm", "bootstrap", frac_cells = 1, B = 500, seed = 125)
), fill = TRUE)


model_gls_all_temp <- rbindlist(list(
  fit_full_by_region_temp(pix_cba, "CBA", "gls"),
  fit_full_by_region_temp(pix_eba, "EBA", "gls"),
  fit_full_by_region_temp(pix_sba, "SBA", "gls")
), fill = TRUE)

boot_gls_all_temp <- rbindlist(list(
  run_resample_region_temp(pix_cba, "CBA", "gls", "bootstrap", frac_cells = 1, B = 500, seed = 223),
  run_resample_region_temp(pix_eba, "EBA", "gls", "bootstrap", frac_cells = 1, B = 500, seed = 224),
  run_resample_region_temp(pix_sba, "SBA", "gls", "bootstrap", frac_cells = 1, B = 500, seed = 225)
), fill = TRUE)

fracs_temp <- c(0.25, 0.15, 0.05)

run_grid_temp <- function(dt_region_temp, region_name, model_type, seed_base) {
  out_temp <- vector("list", length(fracs_temp))
  
  for (i in seq_along(fracs_temp)) {
    out_temp[[i]] <- run_resample_region_temp(
      dt_region_temp = dt_region_temp,
      region_name = region_name,
      model_type = model_type,
      method = "subsample",
      frac_cells = fracs_temp[i],
      B = 500,
      seed = seed_base + i
    )
  }
  
  rbindlist(out_temp, fill = TRUE)
}

sub_lmm_all_temp <- rbindlist(list(
  run_grid_temp(pix_cba, "CBA", "lmm", 300),
  run_grid_temp(pix_eba, "EBA", "lmm", 400),
  run_grid_temp(pix_sba, "SBA", "lmm", 500)
), fill = TRUE)

sub_gls_all_temp <- rbindlist(list(
  run_grid_temp(pix_cba, "CBA", "gls", 600),
  run_grid_temp(pix_eba, "EBA", "gls", 700),
  run_grid_temp(pix_sba, "SBA", "gls", 800)
), fill = TRUE)

sum_boot_lmm_temp <- summarise_resamples_temp(boot_lmm_all_temp)
sum_boot_gls_temp <- summarise_resamples_temp(boot_gls_all_temp)
sum_sub_lmm_temp  <- summarise_resamples_temp(sub_lmm_all_temp)
sum_sub_gls_temp  <- summarise_resamples_temp(sub_gls_all_temp)

