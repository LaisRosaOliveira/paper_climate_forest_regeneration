### Funções




```{r}

aggregate_prec <- function(dt_in) {
  agg_prec <- dt_in[
    ,
    .(
      Prec = mean(Prec, na.rm = TRUE),
      n_eff = .N
    ),
    by = .(Ano, Region, ff_area, Tipo)
  ]
  
  agg_prec[, Ano_num := as.integer(Ano)]
  agg_prec[, grupo_var := interaction(Tipo, ff_area, drop = TRUE)]
  agg_prec[, estrato_id := interaction(Tipo, ff_area, drop = TRUE)]
  
  as.data.frame(agg_prec)
}


fit_model_prec <- function(dat_agg_region_prec, model_type = c("lmm", "gls")) {
  model_type <- match.arg(model_type)
  
  if (model_type == "lmm") {
    fit_prec <- lmer(
      Prec ~ ff_area * Tipo + (1 | Ano),
      data = dat_agg_region_prec
    )
  } else {
    fit_prec <- gls(
      Prec ~ ff_area * Tipo + factor(Ano),
      weights = varComb(
        varPower(form = ~ n_eff),
        varIdent(form = ~ 1 | grupo_var)
      ),
      data = dat_agg_region_prec,
      method = "REML",
      na.action = na.omit
    )
  }
  
  attr(fit_prec, "boot_data_prec") <- dat_agg_region_prec
  fit_prec
}


extract_pf_sf_contrasts_prec <- function(model_obj_prec, region_name,
                                         rep_id = NA_integer_,
                                         source_label = NA_character_,
                                         model_type = NA_character_,
                                         method = NA_character_,
                                         frac_cells = NA_real_) {
  
  boot_data_prec <- attr(model_obj_prec, "boot_data_prec")
  
  emm_prec <- emmeans(
    model_obj_prec,
    ~ Tipo | ff_area,
    data = boot_data_prec
  )
  
  contr_prec <- summary(
    pairs(emm_prec, by = "ff_area", adjust = "none"),
    infer = c(TRUE, TRUE)
  ) %>%
    as.data.frame()
  
  contr_prec <- contr_prec[
    contr_prec$contrast %in% c("PF - SF_early", "PF - SF_intermediate", "PF - SF_advanced"),
  ]
  
  if (nrow(contr_prec) == 0) return(NULL)
  
  if (!"lower.CL" %in% names(contr_prec)) contr_prec$lower.CL <- NA_real_
  if (!"upper.CL" %in% names(contr_prec)) contr_prec$upper.CL <- NA_real_
  
  contr_prec$region <- region_name
  contr_prec$rep <- rep_id
  contr_prec$source <- source_label
  contr_prec$model_type <- model_type
  contr_prec$method <- method
  contr_prec$frac_cells <- frac_cells
  
  contr_prec
}


fit_full_by_region_prec <- function(dt_region_prec, region_name, model_type) {
  dat_agg_region_prec <- aggregate_prec(dt_region_prec)
  fit_prec <- fit_model_prec(dat_agg_region_prec, model_type = model_type)
  
  extract_pf_sf_contrasts_prec(
    fit_prec,
    region_name = region_name,
    rep_id = NA_integer_,
    source_label = paste0("model_", model_type),
    model_type = model_type,
    method = "full",
    frac_cells = 1
  )
}


fit_one_resample_region_prec <- function(dt_region_prec, region_name, rep_id,
                                         model_type = c("lmm","gls"),
                                         method = c("bootstrap","subsample"),
                                         frac_cells = 1) {
  
  model_type <- match.arg(model_type)
  method <- match.arg(method)
  
  ids_prec <- unique(dt_region_prec$cell_id)
  n_ids_prec <- length(ids_prec)
  n_use_prec <- max(1, floor(n_ids_prec * frac_cells))
  
  if (method == "bootstrap") {
    sampled_ids_prec <- sample(ids_prec, size = n_use_prec, replace = TRUE)
    sampled_dt_prec <- data.table(cell_id = sampled_ids_prec)[, .N, by = cell_id]
    setnames(sampled_dt_prec, "N", "n_rep")
    
    res_dt_prec <- merge(
      dt_region_prec,
      sampled_dt_prec,
      by = "cell_id",
      all = FALSE,
      allow.cartesian = TRUE
    )
    
    res_dt_prec <- res_dt_prec[rep(seq_len(.N), n_rep)]
    res_dt_prec[, n_rep := NULL]
    
  } else {
    sampled_ids_prec <- sample(ids_prec, size = n_use_prec, replace = FALSE)
    res_dt_prec <- dt_region_prec[cell_id %in% sampled_ids_prec]
  }
  
  dat_agg_region_prec <- aggregate_prec(res_dt_prec)
  
  fit_prec <- tryCatch(
    fit_model_prec(dat_agg_region_prec, model_type = model_type),
    error = function(e) NULL
  )
  
  if (is.null(fit_prec)) return(NULL)
  
  extract_pf_sf_contrasts_prec(
    fit_prec,
    region_name = region_name,
    rep_id = rep_id,
    source_label = paste0(method, "_", model_type, "_", frac_cells),
    model_type = model_type,
    method = method,
    frac_cells = frac_cells
  )
}


run_resample_region_prec <- function(dt_region_prec, region_name,
                                     model_type = c("lmm","gls"),
                                     method = c("bootstrap","subsample"),
                                     frac_cells = 1,
                                     B = 500,
                                     seed = 123) {
  
  model_type <- match.arg(model_type)
  method <- match.arg(method)
  
  set.seed(seed)
  res_list_prec <- vector("list", B)
  
  for (b in seq_len(B)) {
    cat(method, "|", model_type, "|", region_name, "| frac =", frac_cells, "|", b, "of", B, "\n")
    
    res_list_prec[[b]] <- fit_one_resample_region_prec(
      dt_region_prec = dt_region_prec,
      region_name = region_name,
      rep_id = b,
      model_type = model_type,
      method = method,
      frac_cells = frac_cells
    )
  }
  
  rbindlist(res_list_prec, fill = TRUE)
}


summarise_resamples_prec <- function(dt_res_prec) {
  dt_res_prec[
    ,
    .(
      n_rep = .N,
      mean_est = mean(estimate, na.rm = TRUE),
      sd_est = sd(estimate, na.rm = TRUE),
      q025 = quantile(estimate, 0.025, na.rm = TRUE),
      q975 = quantile(estimate, 0.975, na.rm = TRUE),
      prop_pos = mean(estimate > 0, na.rm = TRUE)
    ),
    by = .(region, ff_area, contrast, source, model_type, method, frac_cells)
  ]
}

```




### Execução




```{r,eval = FALSE, echo = TRUE}

model_lmm_all_prec <- rbindlist(list(
  fit_full_by_region_prec(pix_cba, "CBA", "lmm"),
  fit_full_by_region_prec(pix_eba, "EBA", "lmm"),
  fit_full_by_region_prec(pix_sba, "SBA", "lmm")
), fill = TRUE)

boot_lmm_all_prec <- rbindlist(list(
  run_resample_region_prec(pix_cba, "CBA", "lmm", "bootstrap", frac_cells = 1, B = 500, seed = 123),
  run_resample_region_prec(pix_eba, "EBA", "lmm", "bootstrap", frac_cells = 1, B = 500, seed = 124),
  run_resample_region_prec(pix_sba, "SBA", "lmm", "bootstrap", frac_cells = 1, B = 500, seed = 125)
), fill = TRUE)


model_gls_all_prec <- rbindlist(list(
  fit_full_by_region_prec(pix_cba, "CBA", "gls"),
  fit_full_by_region_prec(pix_eba, "EBA", "gls"),
  fit_full_by_region_prec(pix_sba, "SBA", "gls")
), fill = TRUE)

boot_gls_all_prec <- rbindlist(list(
  run_resample_region_prec(pix_cba, "CBA", "gls", "bootstrap", frac_cells = 1, B = 500, seed = 223),
  run_resample_region_prec(pix_eba, "EBA", "gls", "bootstrap", frac_cells = 1, B = 500, seed = 224),
  run_resample_region_prec(pix_sba, "SBA", "gls", "bootstrap", frac_cells = 1, B = 500, seed = 225)
), fill = TRUE)

fracs_prec <- c(0.25, 0.15, 0.05)

run_grid_prec <- function(dt_region_prec, region_name, model_type, seed_base) {
  out_prec <- vector("list", length(fracs_prec))
  
  for (i in seq_along(fracs_prec)) {
    out_prec[[i]] <- run_resample_region_prec(
      dt_region_prec = dt_region_prec,
      region_name = region_name,
      model_type = model_type,
      method = "subsample",
      frac_cells = fracs_prec[i],
      B = 500,
      seed = seed_base + i
    )
  }
  
  rbindlist(out_prec, fill = TRUE)
}

sub_lmm_all_prec <- rbindlist(list(
  run_grid_prec(pix_cba, "CBA", "lmm", 300),
  run_grid_prec(pix_eba, "EBA", "lmm", 400),
  run_grid_prec(pix_sba, "SBA", "lmm", 500)
), fill = TRUE)

sub_gls_all_prec <- rbindlist(list(
  run_grid_prec(pix_cba, "CBA", "gls", 600),
  run_grid_prec(pix_eba, "EBA", "gls", 700),
  run_grid_prec(pix_sba, "SBA", "gls", 800)
), fill = TRUE)

sum_boot_lmm_prec <- summarise_resamples_prec(boot_lmm_all_prec)
sum_boot_gls_prec <- summarise_resamples_prec(boot_gls_all_prec)
sum_sub_lmm_prec  <- summarise_resamples_prec(sub_lmm_all_prec)
sum_sub_gls_prec  <- summarise_resamples_prec(sub_gls_all_prec)

